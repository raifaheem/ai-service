{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Request rate (req/s)",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(healthai_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "graphMode": "area"
      },
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "stat",
      "title": "5xx rate (%)",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "100 * sum(rate(healthai_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(healthai_requests_total[5m])), 0.0001)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "OpenAI circuit",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "healthai_circuit_breaker_state{name=\"openai\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"text": "closed", "color": "green"}}, "type": "value"},
            {"options": {"1": {"text": "half-open", "color": "yellow"}}, "type": "value"},
            {"options": {"2": {"text": "OPEN", "color": "red"}}, "type": "value"}
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Qdrant circuit",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "healthai_circuit_breaker_state{name=\"qdrant\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"text": "closed", "color": "green"}}, "type": "value"},
            {"options": {"1": {"text": "half-open", "color": "yellow"}}, "type": "value"},
            {"options": {"2": {"text": "OPEN", "color": "red"}}, "type": "value"}
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Request latency p50 / p95 / p99",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(healthai_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(healthai_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(healthai_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "timeseries",
      "title": "Requests by status",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "sum by (status) (rate(healthai_requests_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "timeseries",
      "title": "Intent distribution",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "sum by (category) (rate(healthai_intent_total[5m]))",
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RAG hit rate",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "expr": "sum(rate(healthai_rag_requests_total{hit=\"true\"}[5m])) / clamp_min(sum(rate(healthai_rag_requests_total[5m])), 0.0001)",
          "legendFormat": "hit rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "type": "timeseries",
      "title": "OpenAI token usage (per minute)",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {
          "expr": "sum by (call_type, type) (rate(healthai_openai_tokens_total[5m])) * 60",
          "legendFormat": "{{call_type}} / {{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active conversations",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 20},
      "targets": [
        {
          "expr": "healthai_active_conversations",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Qdrant collection size (chunks)",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 20},
      "targets": [
        {
          "expr": "healthai_qdrant_collection_size",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["health-ai"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "health-ai overview",
  "uid": "health-ai-overview",
  "version": 1,
  "weekStart": ""
}

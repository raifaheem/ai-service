# Knowledge base files are mounted into the seed service at runtime, not baked
# into the image. Seed + backup scripts are copied in so the compose `seed` /
# `backup` profiles can invoke them.
data

# OS junk
.DS_Store
Thumbs.db

# Local plans
plans

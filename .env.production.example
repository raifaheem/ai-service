# ============================================================================
# health-ai-service — PRODUCTION environment template
#
# How to use:
#   1. cp .env.production.example .env.production
#   2. Fill in the REPLACE_ME values from your secret store (1Password / Vault /
#      sealed-secrets / kubernetes Secret).
#   3. Deploy:  docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#                 --env-file .env.production up -d
#
# `.env.production` is gitignored — never commit the filled-in copy.
#
# Every application value below is validated at startup by
# app/config.py::_validate_prod_safety. A misconfiguration crashes the
# container loudly rather than booting unsafe.
#
# Operational values (DUCKDNS_*, CADDY_DOMAIN, GRAFANA_*, TELEGRAM_*) are
# consumed by docker-compose and the bootstrap script, not by the app.
# ============================================================================

# --- Application --------------------------------------------------------------
# MUST be exactly "production" (whitelist enforced via Literal in config.py).
# "prod" / "PRODUCTION" / "stg" all fail with ValidationError at startup.
APP_ENV=production
APP_NAME=health-ai-service
APP_VERSION=1.0.0

# CORS — list every consumer origin explicitly. '*' is rejected in production.
ALLOWED_ORIGINS=https://REPLACE_ME.your-domain.tld,https://admin.REPLACE_ME.your-domain.tld

# Dev-only /v1/rag/* endpoints — must be false in prod.
ENABLE_DEV_ROUTES=false

# --- OpenAI -------------------------------------------------------------------
OPENAI_API_KEY=REPLACE_ME_sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=3
MAX_RESPONSE_TOKENS=1000

# --- Auth ---------------------------------------------------------------------
# Generate with:  openssl rand -hex 32
# Comma-separated for zero-downtime rotation (any listed token is accepted).
# Must be ≥16 chars and not a placeholder (ci-smoke / changeme / dev / test ...).
SERVICE_TOKEN=REPLACE_ME_64_HEX_CHARS

# Bearer token Prometheus uses to scrape /metrics. Generate with:
#   openssl rand -hex 32
# Optional but recommended in prod: keeps the scrape credential separate from
# SERVICE_TOKEN so it can be rotated without touching Laravel.
METRICS_SCRAPE_TOKEN=REPLACE_ME_PROMETHEUS_SCRAPE_TOKEN

# Direct-client JWT auth (Laravel-issued, RS256 only). Leave all three empty if
# clients reach this service exclusively via X-Service-Token (S2S path).
# When JWT_PUBLIC_KEY is set, JWT_AUDIENCE and JWT_ISSUER are REQUIRED in prod.
JWT_PUBLIC_KEY=
JWT_AUDIENCE=
JWT_ISSUER=

# --- Redis --------------------------------------------------------------------
# Password is mandatory in prod (validated by presence of '@' in URL).
REDIS_URL=redis://:REPLACE_ME_REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=REPLACE_ME_REDIS_PASSWORD
REDIS_PREFIX=healthai
REDIS_TTL_SECONDS=86400
REDIS_MAX_TURNS=12
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5

# --- Rate limiting ------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_BURST=5

# --- Qdrant -------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=medical_articles
QDRANT_TIMEOUT=10
RAG_SCORE_THRESHOLD=0.35

# --- Caching ------------------------------------------------------------------
EMBEDDING_CACHE_TTL=86400

# --- Logging ------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# Operational config — consumed by docker-compose / bootstrap script, NOT
# by app/config.py. These are not validated; getting them wrong is a deploy
# issue, not a runtime crash.
# ============================================================================

# Image tag to deploy. The GitHub Actions deploy job exports IMAGE_TAG
# matching the pushed git tag (e.g. v1.0.0); compose interpolates it into
# `image: ghcr.io/raifaheem/ai-service:${IMAGE_TAG}`. `latest` is the safe
# fallback if a manual `docker compose up` happens before the first tag push.
IMAGE_TAG=latest

# --- Caddy (TLS + reverse proxy) ----------------------------------------------
# The public DuckDNS subdomain that Caddy serves over HTTPS. Must match
# ALLOWED_ORIGINS so CORS preflight succeeds end-to-end.
CADDY_DOMAIN=REPLACE_ME.duckdns.org

# --- DuckDNS (dynamic DNS keepalive) ------------------------------------------
# scripts/duckdns_update.sh runs every 5 min via cron and pings DuckDNS to
# keep CADDY_DOMAIN pointing at the VM's current public IP. Oracle gives a
# static IP, but the keepalive removes a manual step if the VM is rebuilt.
DUCKDNS_DOMAIN=REPLACE_ME.duckdns.org
DUCKDNS_TOKEN=REPLACE_ME_DUCKDNS_UUID

# --- Grafana ------------------------------------------------------------------
# Generate with:  openssl rand -hex 32
# Login at https://${CADDY_DOMAIN}/grafana/ as `admin` with this password.
GRAFANA_ADMIN_PASSWORD=REPLACE_ME_GRAFANA_ADMIN_PASSWORD

# --- Telegram alerts (Alertmanager → alertmanager-bot → Telegram) ------------
# 1. Talk to @BotFather → /newbot → save the HTTP API token here.
# 2. Send any message to your bot, then GET
#    https://api.telegram.org/bot<token>/getUpdates → extract chat.id.
TELEGRAM_BOT_TOKEN=REPLACE_ME_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_ME_TELEGRAM_CHAT_ID

# --- Watchtower (self-host auto-update) ---------------------------------------
# Only relevant on the self-host deploy path — Watchtower polls GHCR for new
# images of `ghcr.io/raifaheem/ai-service:${IMAGE_TAG}` and auto-restarts the
# ai container. On the VPS path (CI does SSH + `docker compose pull`),
# Watchtower is harmless but unused.
#
# For self-host: set IMAGE_TAG=latest above so Watchtower watches the rolling
# `latest` tag (CI publishes both vX.Y.Z and `latest` for every tag push).
WATCHTOWER_POLL_INTERVAL_SECONDS=60

# GHCR pull credentials for Watchtower. Create a Personal Access Token at
# https://github.com/settings/tokens with scope `read:packages`. The token is
# safer than your password and can be rotated without affecting anything else.
# Username is your GitHub login.
GHCR_USERNAME=REPLACE_ME_github_username
GHCR_TOKEN=REPLACE_ME_ghcr_pat_with_read_packages

APP_ENV=dev
APP_NAME=health-ai-service
ALLOWED_ORIGINS=*

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

SERVICE_TOKEN=

JWT_PUBLIC_KEY=
JWT_ALG=RS256

REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=healthai
REDIS_TTL_SECONDS=86400
REDIS_MAX_TURNS=12

RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_BURST=5

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=medical_articles

ENABLE_DEV_ROUTES=true
APP_VERSION=1.0.0
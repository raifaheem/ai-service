# ============================================================================
# health-ai-service — environment configuration
#
# Copy to `.env`, fill in secrets, then `docker compose up -d` or
# `uvicorn app.main:app --reload --port 8001`.
#
# Variables map 1:1 to fields in app/config.py::Settings (case-insensitive).
# ============================================================================

# --- Application --------------------------------------------------------------
APP_ENV=dev                       # dev | staging | production
APP_NAME=health-ai-service
APP_VERSION=1.0.0
# Comma-separated list of origins in prod (https://app.example.com,https://admin.example.com).
# '*' is allowed only in dev/staging; with '*' credentials are disabled by CORS middleware.
ALLOWED_ORIGINS=*
# Mounts /v1/rag/* dev-only endpoints used by legacy HTTP seed scripts.
# MUST be false when APP_ENV=production (validated at startup).
ENABLE_DEV_ROUTES=true

# --- OpenAI -------------------------------------------------------------------
OPENAI_API_KEY=                   # required; sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=3
MAX_RESPONSE_TOKENS=1000

# --- Auth ---------------------------------------------------------------------
# Comma-separated for rotation: any listed token is accepted. MUST be a strong
# random value in production (validated at startup — placeholders rejected).
SERVICE_TOKEN=
# RS256 public key in PEM (single line with literal \n or multiline). Optional
# unless direct-client JWT access is enabled.
JWT_PUBLIC_KEY=
JWT_ALG=RS256

# --- Redis --------------------------------------------------------------------
# In production MUST include password: redis://:pwd@host:6379/0 (validated).
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=healthai
REDIS_TTL_SECONDS=86400
REDIS_MAX_TURNS=12
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5

# --- Rate limiting (per user per minute, sliding window) ----------------------
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_BURST=5

# --- Qdrant (RAG) -------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                   # optional; required for Qdrant Cloud
QDRANT_COLLECTION=medical_articles
QDRANT_TIMEOUT=10
# Minimum cosine similarity for a chunk to be included in RAG context.
# Too high → "RAG silently went cold" (no chunks retrieved, answers degrade).
RAG_SCORE_THRESHOLD=0.35

# --- Caching ------------------------------------------------------------------
EMBEDDING_CACHE_TTL=86400         # embeddings cached for 24h

# --- Logging ------------------------------------------------------------------
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text                   # text | json

# --- Offline tooling (seed / verify scripts) ----------------------------------
# Used by scripts/seed_knowledge_base.py and scripts/verify_knowledge_base.py.
# Override with --base-url on the CLI when talking to Docker (http://localhost:8001) or prod.
SEED_BASE_URL=http://localhost:8001
